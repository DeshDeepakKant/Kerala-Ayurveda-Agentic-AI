# Kerala Ayurveda RAG System Configuration

# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Anthropic API Configuration (alternative)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Vector Store Configuration
CHROMA_PERSIST_DIRECTORY=./data/indexes/chroma
VECTOR_DIMENSION=3072

# BM25 Configuration
BM25_K1=1.5
BM25_B=0.75

# Retrieval Configuration
RETRIEVAL_TOP_K=10
FINAL_TOP_K=5
RRF_CONSTANT=60

# CRAG Configuration
CRAG_HIGH_CONFIDENCE_THRESHOLD=0.7
CRAG_LOW_CONFIDENCE_THRESHOLD=0.3
MAX_QUERY_REWRITES=3

# Agent Configuration
MAX_REFLECTION_ITERATIONS=3
HALLUCINATION_THRESHOLD=0.10
CITATION_COVERAGE_THRESHOLD=0.85
BRAND_ALIGNMENT_THRESHOLD=0.80

# Evaluation Configuration
RAGAS_BATCH_SIZE=10

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/kerala_ayurveda_rag.log
